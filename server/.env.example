# Template das variáveis de ambiente do server.
# Copia pra `.env` no VPS e ajusta os valores.
# NUNCA commita o `.env` real (o .gitignore já cobre isso).

# Porta que o Node escuta. nginx faz reverse proxy de 443 pra essa porta.
# Padrão é 3001 (deixa 3000 livre pra caso de coexistir com outro app no VPS).
# O ecosystem.config.cjs do pm2 já injeta esse valor — esse .env é só pra
# desenvolvimento solto fora do pm2 (ex: rodar `tsx src/index.ts` direto).
PORT=3001

# Quantos ms o server espera um cliente reconectar antes de decretar W.O.
# 30s é razoável pra Wi-Fi instavel. Pra testes locais você usa 2000.
DISCONNECT_TIMEOUT_MS=30000

# (Reservado pra Fase 7+, não usado ainda)
NODE_ENV=production
