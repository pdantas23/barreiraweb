{
  "name": "barreira",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "web",
    "server",
    "shared"
  ],
  "overrides": {
    "react": "19.1.0"
  },
  "scripts": {
    "dev:web": "npm --workspace=barreira-web run dev",
    "dev:server": "npm --workspace=@barreira/server run dev",
    "test:client": "npm --workspace=@barreira/server run test-client",
    "test:room": "npm --workspace=@barreira/server run test-room",
    "test:game": "npm --workspace=@barreira/server run test-game",
    "test:reconnect": "npm --workspace=@barreira/server run test-reconnect",
    "test:wo": "npm --workspace=@barreira/server run test-wo",
    "play:bot": "npm --workspace=@barreira/server run play-bot",
    "typecheck:shared": "npm --workspace=@barreira/shared run typecheck",
    "typecheck:server": "npm --workspace=@barreira/server run typecheck"
  }
}
